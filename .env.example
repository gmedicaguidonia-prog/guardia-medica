# ── Supabase ─────────────────────────────────────────────────────────
# Copia questo file in `.env` e inserisci le credenziali del progetto.
# Finché questi valori sono VUOTI, l'app gira in "modalità DEV":
#   - dati salvati nel localStorage del browser (niente backend)
#   - login simulato (scegli il ruolo dalla pagina di accesso)
# Appena li compili, l'app passa automaticamente al backend Supabase reale.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth Client ID (Web) per "Sincronizza con Google Calendar".
# Valore pubblico (finisce nel bundle JS). Si crea in Google Cloud Console:
#   APIs & Services → Credentials → OAuth client ID → Web application
# Lasciare vuoto = la sincronizzazione calendario resta disattivata.
VITE_GOOGLE_OAUTH_CLIENT_ID=
